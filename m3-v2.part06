function load(){try{let x=JSON.parse(localStorage.getItem(K));if(x&&Array.isArray(x.rules))return{rules:x.rules,over:x.over||{},expenses:x.expenses||[],cats:[...new Set([...CATS,...(x.cats||[])])],tasks:{interval:false,series:false,actions:false,amount:false,...(x.tasks||{})},last:x.last||today()}}catch(e){}return{rules:[],over:{},expenses:[],cats:[...CATS],tasks:{interval:false,series:false,actions:false,amount:false},last:today()}}S=load();month=monthStart(today());function save(){localStorage.setItem(K,JSON.stringify(S))}function toast(t){let e=$('toast');e.textContent=t;e.classList.add('show');clearTimeout(toast.t);toast.t=setTimeout(()=>e.classList.remove('show'),2200)}function openM(id){$(id).classList.add('open');scrollY=window.scrollY;document.body.style.top=`-${scrollY}px`;document.body.classList.add('locked');let sh=$(id).querySelector('.sheet');if(sh)sh.scrollTop=0}function closeM(el){(typeof el==='string'?$(el):el).classList.remove('open');if(!document.querySelector('.modal.open')){document.body.classList.remove('locked');document.body.style.top='';window.scrollTo(0,scrollY)}}function key(r,i){return`${r}:${i}`}function ov(r,i){return S.over[key(r,i)]||{}}function setOv(r,i,p){S.over[key(r,i)]={...S.over[key(r,i)],...p};save()}
function amountAt(r,i){let a=r.base;for(let v of [...(r.versions||[])].sort((a,b)=>a.from-b.from))if(i>=v.from)a=v.amount;return ov(r.id,i).amount??a}function sched(r,i){return ov(r.id,i).date||addInt(r.start,r.n,r.unit,i)}function maxIndex(r,through){if(r.kind==='one')return 0;if(r.end==='count')return Math.max(0,r.count-1);let i=0;while(i<600){let d=addInt(r.start,r.n,r.unit,i);if(r.end==='date'&&cmp(d,r.endDate)>0)return i-1;if(cmp(d,through)>0)return i;i++}return 599}function occ(r,i){let o=ov(r.id,i);return{rule:r,index:i,id:key(r.id,i),date:sched(r,i),expected:amountAt(r,i),status:o.status||'planned',actualDate:o.actualDate||null,actual:o.actual??null,expense:o.expense||null,from:o.from||null}}function allThrough(through){let out=[];for(let r of S.rules.filter(x=>x.active!==false)){let max=maxIndex(r,through);for(let i=0;i<=max&&i<600;i++){let base=addInt(r.start,r.n,r.unit,i);if(r.end==='date'&&cmp(base,r.endDate)>0)break;out.push(occ(r,i))}}return out}function status(o){if(o.status!=='planned')return o.status;if(cmp(o.date,today())<0)return'overdue';if(o.date===today())return'today';return'planned'}function intervalText(r){if(r.kind==='one')return'Đ Đ°Đ·ĐľĐ˛Ń‹Đą ĐżĐ»Đ°Ń‚Ń‘Đ¶';let u={days:['Đ´ĐµĐ˝ŃŚ','Đ´Đ˝ŃŹ','Đ´Đ˝ĐµĐą'],weeks:['Đ