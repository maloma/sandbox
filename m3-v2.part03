step="0.01" inputmode="decimal" placeholder="0,00"></label><div class="field"><span id="dateLabel">Дата первого платежа</span><button id="startBtn" class="date-btn"></button><input id="startDate" type="hidden"></div></div>
<div id="repeatFields" class="stack"><div class="field"><span>Повторять</span><div class="inline"><input id="intervalN" type="number" min="1" max="120" step="1" value="1" inputmode="numeric"><select id="intervalUnit"><option value="days">дней</option><option value="weeks">недель</option><option value="months" selected>месяцев</option><option value="years">лет</option></select></div><div class="tiny">Например: каждые 3 месяца.</div></div><label class="field"><span>Когда закончить</span><select id="endMode"><option value="unlimited">Без ограничения</option><option value="count">После указанного количества платежей</option><option value="date">К указанной дате</option></select></label><label id="countField" class="field hidden"><span>Сколько платежей всего</span><input id="totalCount" type="number" min="1" max="240" value="11" inputmode="numeric"></label><div id="endDateField" class="field hidden"><span>Последняя допустимая дата</span><button id="endBtn" class="date-btn"></button><input id="endDate" type="hidden"></div></div>
<label class="field"><span>Комментарий <span class="tiny">необязательно</span></span><textarea id="note" rows="2" maxlength="180" placeholder="Сумма может отличаться на несколько центов"></textarea></label><div class="notice"><strong>Оплата:</strong> кнопка «Оплачено» прямо в списке создаёт связанную расходную операцию. Фактическую сумму и дату можно исправить после этого.</div><button id="saveRule" class="btn primary block">Сохранить правило</button></section>
<section id="calendar" class="card stack swipe"><div class="row between"><h2>Платежи</h2><button id="clear" class="btn ghost small">Очистить тестовые данные</button></div><div class="month-nav"><button id="prev" class="btn ghost">‹</button><div id="monthTitle" class="month-title"></div><button id="next" class="btn ghost">›</button></div><div class="tiny" style="text-align:center">В каждом дне показано количество платежей и их общая сумма.</div><div id="overdue"></div><div id="list"></div></section>
