${esc(r.title)}</strong><div class="tiny">${esc(r.cat)}</div><div class="notice">${intervalText(r)}<br>Начало: ${fd(r.start)}<br>Завершение: ${ending}</div><button id="editRuleBtn" class="btn primary block">Редактировать правило</button><button id="archiveRuleBtn" class="btn danger block">Завершить правило</button>`;openM('ruleModal');$('editRuleBtn').onclick=()=>editRule(r);$('archiveRuleBtn').onclick=()=>{if(confirm('Завершить правило? История оплат сохранится.')){r.active=false;save();closeM('ruleModal');render();toast('Правило завершено')}}}function editRule(r){editId=r.id;$('editBanner').classList.remove('hidden');$('formTitle').textContent='Редактировать правило';$('saveRule').textContent='Сохранить изменения';$('title').value=r.title;$('amount').value=r.base;$('category').value=r.cat;$('note').value=r.note||'';$('intervalN').value=r.n;$('intervalUnit').value=r.unit;$('endMode').value=r.end;$('totalCount').value=r.count||11;setKind(r.kind);setDate('startDate',r.start);setDate('endDate',r.endDate||addYears(r.start,1));toggleEnd();closeM('ruleModal');$('form').scrollIntoView({behavior:'smooth'})}
function action(e){let row=e.target.closest('[data-occ]'),b=e.target.closest('[data-a]');if(!row||!b)return;let o=findOcc(row.dataset.occ);if(!o)return;if(b.dataset.a==='pay')pay(o);if(b.dataset.a==='move')openMove(o);if(b.dataset.a==='amount')openAmount(o);if(b.dataset.a==='actual')openActual(o);if(b.dataset.a==='rule')openRule(o)}function prepDate(target){dateTarget=target;let[y,m,d]=($(target).value||today()).split('-').map(Number),months=['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];$('dm').innerHTML=months.map((x,i)=>`<option value="${i+1}">${x}</option>`).join('');let cy=new Date().getFullYear();$('dy').innerHTML=Array.from({length:16},(_,i)=>cy-5+i).map(y=>`<option>${y}</option>`).join('');$('dm').value=m;$('dy').value=y;days(d);openM('dateModal')}function days(pref){let y=+$('dy').value,m=+$('dm').value,max=new Date(y,m,0).getDate(),d=Math.min(+(pref||$('dd').value||1),max);$('dd').innerHTML=Array.from({length:max},(_,i)=>`<option>${i+1}</option>`).join('');$('dd').value=d}function applyDate(){setDate(dateTarget,`${$('dy').value}-${pad($('dm').value)}-${pad($('dd').value)}`);closeM('dateModal')}
function changeMonth(n){month=addMonths(month,n);render()}function finish(){let done=Object.values(S.tasks).filter(Boolean).length,all=done===4,text=`FamilyPilot M3 Founder Test v2\nDate: ${today()}\nViewport: ${innerWidth}x${innerHeight}\nArbitrary interval: ${S.tasks.interval?'PASS':'NOT COMPLETED'}\nFinite series: ${S.tasks.series?'PASS':'NOT COMPLETED'}\nQuick pay and one-payment reschedule: ${S.tasks.actions?'PASS':'NOT COMPLETED'}\nFuture amount version: ${S.tasks.amount?'PASS':