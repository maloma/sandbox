<div id="ruleModal" class="modal"><div class="sheet"><div class="grab"></div><div class="row between"><h2>Правило обязательства</h2><button class="btn ghost small" data-close>Закрыть</button></div><div id="ruleBox" class="card stack"></div></div></div>
<div id="finishModal" class="modal"><div class="sheet"><div class="grab"></div><div class="row between"><h2>Результат теста</h2><button class="btn ghost small" data-close>Закрыть</button></div><div id="finishStatus" class="notice"></div><div id="evidence" class="evidence" style="margin-top:12px"></div><button id="copy" class="btn primary block" style="margin-top:12px">Скопировать</button></div></div><div id="toast" class="toast"></div>
<script>
(()=>{'use strict';const K='familypilot.m3.v2',MAX=999999.99,CATS=['Жильё','Коммунальные услуги','Связь и подписки','Страхование','Налоги и документы','Кредиты','Транспорт','Здоровье','Дети','Другое'];let S,editId=null,kind='recurring',month,dateTarget=null,selected=null,scrollY=0,touchX=null;const $=id=>document.getElementById(id),pad=n=>String(n).padStart(2,'0'),round=n=>Math.round((Number(n)||0)*100)/100;
function today(){let d=new Date;return`${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`}function pdate(v){let[y,m,d]=v.split('-').map(Number);return new Date(y,m-1,d)}function iso(d){return`${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`}function monthStart(v){let d=pdate(v);return`${d.getFullYear()}-${pad(d.getMonth()+1)}-01`}function monthEnd(v){let d=pdate(v);return iso(new Date(d.getFullYear(),d.getMonth()+1,0))}function addDays(v,n){let d=pdate(v);d.setDate(d.getDate()+n);return iso(d)}function addMonths(v,n){let d=pdate(v),day=d.getDate(),t=new Date(d.getFullYear(),d.getMonth()+n,1),last=new Date(t.getFullYear(),t.getMonth()+1,0).getDate();t.setDate(Math.min(day,last));return iso(t)}function addYears(v,n){let d=pdate(v),y=d.getFullYear()+n,m=d.getMonth(),day=d.getDate(),last=new Date(y,m+1,0).getDate();return iso(new Date(y,m,Math.min(day,last)))}function addInt(v,n,u,i){let x=n*i;if(u==='days')return addDays(v,x);if(u==='weeks')return addDays(v,x*7);if(u==='months')return addMonths(v,x);return addYears(v,x)}function cmp(a,b){return String(a).localeCompare(String(b))}function fd(v){return new Intl.DateTimeFormat('ru-RU',{day:'2-digit',month:'short',year:'numeric'}).format(pdate(v))}function fday(v){return new Intl.DateTimeFormat('ru-RU',{day:'numeric',month:'long'}).format(pdate(v))}function fm(v){return new Intl.DateTimeFormat('ru-RU',{month:'long',year:'numeric'}).form