<!doctype html><html lang="ru"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"><meta name="theme-color" content="#0f766e"><title>FamilyPilot — M3 Обязательства</title>
<style>
:root{--bg:#f4f7f6;--card:#fff;--ink:#17332d;--muted:#687d78;--line:#d8e4e1;--brand:#0f766e;--soft:#eaf3f1;--ok:#267346;--okbg:#e9f6ee;--bad:#b42318;--badbg:#fff0ee;--warn:#795b13;--warnbg:#fff8e7}*{box-sizing:border-box;min-width:0}html{font-family:system-ui,-apple-system,"Segoe UI",sans-serif;background:var(--bg);color:var(--ink)}body{margin:0;background:linear-gradient(#f9fbfa,#f1f5f4)}body.locked{overflow:hidden;position:fixed;width:100%}button,input,select,textarea{font:inherit}input,select,textarea{font-size:16px}.app{max-width:680px;margin:auto;padding-bottom:38px}.top{position:sticky;top:0;z-index:20;background:rgba(244,247,246,.96);backdrop-filter:blur(14px);border-bottom:1px solid var(--line);padding:12px 14px}.row{display:flex;align-items:center;gap:9px}.between{justify-content:space-between}.wrap{flex-wrap:wrap}.brand{display:flex;align-items:center;gap:9px;font-weight:850}.logo{width:36px;height:36px;display:grid;place-items:center;color:#fff;border-radius:12px;background:linear-gradient(145deg,var(--brand),#2ba79b)}.tiny{font-size:12px;color:var(--muted);line-height:1.45}main{padding:12px}.hero{background:linear-gradient(140deg,#0f766e,#0a5c56);color:#fff;border-radius:24px;padding:20px;margin-bottom:12px}.hero h1{font-size:27px;line-height:1.12;margin:7px 0}.hero p{opacity:.92;margin:0;line-height:1.45}.eyebrow{font-size:11px;text-transform:uppercase;letter-spacing:.12em;opacity:.82}.card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:15px;margin-bottom:12px}.soft{background:var(--soft)}.stack{display:grid;gap:12px}h2,h3{margin:0}.btn{border:0;border-radius:13px;min-height:44px;padding:10px 13px;font-weight:780;cursor:pointer;display:inline-flex;justify-content:center;align-items:center;gap:7px;touch-action:manipulation}.primary{background:var(--brand);color:#fff}.secondary{background:#dfeeea;color:#0b5f59}.ghost{background:#fff;border:1px solid var(--line);color:var(--ink)}.success{background:var(--ok);color:#fff}.danger{background:var(--badbg);color:var(--bad);border:1px solid #f4cbc5}.block{width:100%}.small{min-height:36px;padding:7px 10px;font-size:12px}.field{display:grid;gap:7px;font-size:13px;font-weight:760;color:#36534d}.field input,.field select,.field textarea{width:100%;border:1px solid var(--line);border-radius:13px;padding:12px;background:#fff;color:var(--ink)}.label-row{display:flex;align-items:center;justify-content:space-between;gap:10px}.help{width:28px;height:28px;min-height:28px;border-radius:50%;border:1px solid var(--line);background:#fff;color:var(--brand);font-weight:850;padding:0}.hidden{display:none!important}.notice{padding:12px;border-radius:14px;background:#edf5f3;border:1px solid #d7e6e2;font-size:13px;line-height:1.5