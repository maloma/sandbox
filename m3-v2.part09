ано из обязательства'});setOv(o.rule.id,o.index,{status:'paid',actualDate:d,actual:o.expected,expense:eid,date:o.date,from:o.from||null});S.tasks.actions=true;render();toast('Оплачено. Расход создан')}function openActual(o){selected=o;$('actualName').textContent=o.rule.title;$('expectedText').textContent=`Ожидалось ${money(o.expected)} · ${fd(o.date)}`;$('actualAmount').value=o.actual??o.expected;setDate('actualDate',o.actualDate||today());$('undoActual').classList.toggle('hidden',o.status!=='paid');openM('actualModal')}function saveActual(){let a=round($('actualAmount').value),d=$('actualDate').value;if(!(a>0&&a<=MAX))return toast('Введите корректную сумму');let e=S.expenses.find(x=>x.id===selected.expense);if(!e){e={id:uid(),occ:selected.id,title:selected.rule.title,cat:selected.rule.cat,comment:'Создано из обязательства'};S.expenses.push(e)}Object.assign(e,{amount:a,date:d});setOv(selected.rule.id,selected.index,{status:'paid',actualDate:d,actual:a,expense:e.id,date:selected.date,from:selected.from||null});S.tasks.actions=true;closeM('actualModal');render();toast('Оплата исправлена')}function undo(){let o=ov(selected.rule.id,selected.index);S.expenses=S.expenses.filter(x=>x.id!==o.expense);setOv(selected.rule.id,selected.index,{status:'planned',actualDate:null,actual:null,expense:null,date:selected.date,from:selected.from||null});closeM('actualModal');render();toast('Оплата отменена')}
function openMove(o){selected=o;$('moveName').textContent=`${o.rule.title} · было ${fd(o.date)}`;setDate('moveDate',addDays(o.date,1));openM('moveModal')}function saveMove(){let d=$('moveDate').value;setOv(selected.rule.id,selected.index,{date:d,from:selected.from||selected.date});S.tasks.actions=true;closeM('moveModal');render();toast('Перенесён только выбранный платёж')}function openAmount(o){selected=o;$('amountName').textContent=`${o.rule.title} · ${fd(o.date)}`;$('newAmount').value=o.expected;$('amountScope').value='next';openM('amountModal')}function saveAmount(){let a=round($('newAmount').value),scope=$('amountScope').value;if(!(a>0&&a<=MAX))return toast('Введите корректную сумму');if(scope==='only')setOv(selected.rule.id,selected.index,{amount:a,date:selected.date,from:selected.from||null});else{let from=scope==='current'?selected.index:selected.index+1,r=selected.rule;r.versions=(r.versions||[]).filter(v=>v.from!==from);r.versions.push({from,amount:a})}S.tasks.amount=true;save();closeM('amountModal');render();toast(scope==='only'?'Изменён один платёж':'Новая сумма применена к будущим платежам')}
function openRule(o){let r=o.rule,ending=r.kind==='one'?'Один платёж':r.end==='unlimited'?'Без ограничения':r.end==='count'?`${r.count} платежей`:`До ${fd(r.endDate)}`;$('ruleBox').innerHTML=`<strong>