љ–µ–і–µ–ї—О','–љ–µ–і–µ–ї–Є','–љ–µ–і–µ–ї—М'],months:['–Љ–µ—Б—П—Ж','–Љ–µ—Б—П—Ж–∞','–Љ–µ—Б—П—Ж–µ–≤'],years:['–≥–Њ–і','–≥–Њ–і–∞','–ї–µ—В']}[r.unit];return`–Ъ–∞–ґ–і—Л–µ ${r.n} ${pl(r.n,...u)}`}function pill(o){let s=status(o);return s==='paid'?'<span class="pill paid">–Ю–њ–ї–∞—З–µ–љ–Њ</span>':s==='overdue'?'<span class="pill overdue">–Я—А–Њ—Б—А–Њ—З–µ–љ–Њ</span>':s==='today'?'<span class="pill today">–°–µ–≥–Њ–і–љ—П</span>':s==='skipped'?'<span class="pill">–Я—А–Њ–њ—Г—Й–µ–љ–Њ</span>':'<span class="pill">–Ч–∞–њ–ї–∞–љ–Є—А–Њ–≤–∞–љ–Њ</span>'}
function renderCats(){let cur=$('category').value;$('category').innerHTML=S.cats.map(x=>`<option value="${esc(x)}">${esc(x)}</option>`).join('');if(S.cats.includes(cur))$('category').value=cur}function row(o){let done=o.status==='paid'||o.status==='skipped',count=o.rule.end==='count'?` ¬Ј –Я–ї–∞—В—С–ґ ${o.index+1} –Є–Ј ${o.rule.count}`:'',moved=o.from?` ¬Ј –њ–µ—А–µ–љ–µ—Б—С–љ —Б ${fd(o.from)}`:'';return`<div class="payment" data-occ="${o.id}"><div class="row between"><div><div class="payment-title">${esc(o.rule.title)}</div><div class="meta">${esc(o.rule.cat)} ¬Ј ${intervalText(o.rule)}${count}${moved}</div></div><div class="amt">${money(o.status==='paid'?o.actual:o.expected)}</div></div><div class="row between wrap"><div class="meta">${o.status==='paid'?`–Ю–њ–ї–∞—З–µ–љ–Њ ${fd(o.actualDate)}`:`–Я–ї–∞–љ–Њ–≤–∞—П –і–∞—В–∞: ${fd(o.date)}`}</div>${pill(o)}</div><div class="actions">${o.status==='paid'?'<button class="btn ghost" data-a="actual">–Ш–Ј–Љ–µ–љ–Є—В—М –Њ–њ–ї–∞—В—Г</button>':done?'':'<button class="btn success" data-a="pay">вЬУ –Ю–њ–ї–∞—З–µ–љ–Њ</button><button class="btn secondary" data-a="move">–Я–µ—А–µ–љ–µ—Б—В–Є</button><button class="btn ghost" data-a="amount">–Ш–Ј–Љ–µ–љ–Є—В—М —Б—Г–Љ–Љ—Г</button>'}<button class="btn ghost" data-a="rule">–Я—А–∞–≤–Є–ї–Њ</button></div></div>`}function groups(arr){let m=new Map;for(let o of arr){if(!m.has(o.date))m.set(o.date,[]);m.get(o.date).push(o)}return[...m.entries()].sort((a,b)=>cmp(a[0],b[0]))}function group([d,arr]){let sum=round(arr.reduce((s,o)=>s+(o.status==='paid'?o.actual:o.status==='planned'?o.expected:0),0));return`<section class="day-group"><div class="day-head"><span>${fday(d)} ¬Ј ${arr.length} ${pl(arr.length,'–њ–ї–∞—В—С–ґ','–њ–ї–∞—В–µ–ґ–∞','–њ–ї–∞—В–µ–ґ–µ–є')}</span><span>${money(sum)}</span></div>${arr.map(row).join('')}</section>`}function tasks(){for(let [k,id,n] of [['interval','tInterval','1'],['series','tSeries','2'],['actions','tActions','3'],['amount','tAmount','4']]){let e=$(id);e.classList.toggle('done',S.tasks[k]);e.textContent=S.tasks[k]?'вЬУ':n}}function render(){monthTitle.textContent=fm(month);let all=allThrough(monthEnd(addMonths(month,2))),end=monthEnd(month),cur=all.filter(o=>cmp(o.date,month)>=0&&cmp(o.date,end)<=0),late=all.filter(o=>status(o)==='overdue');$('overdue').innerHTML=month===monthStart(today())&&late.length?`<section class="overdue-box"><h3>–Я—А–Њ—Б—А–Њ—З–µ–љ–љ—Л–µ –њ–ї–∞—В–µ–ґ–Є</h3><div class="tiny">–Ю–љ–Є –Њ—Б—В–∞—О—В—Б—П –і–Њ –Њ–