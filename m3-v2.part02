er-events:none;transition:.2s;z-index:90;max-width:calc(100vw - 24px)}.toast.show{opacity:1}.evidence{white-space:pre-wrap;background:#102d27;color:#fff;border-radius:14px;padding:12px;font:12px/1.5 ui-monospace,monospace}.edit{padding:11px 12px;border-radius:14px;background:var(--warnbg);border:1px solid #eedba9;color:#63490c}.swipe{touch-action:pan-y}@media(max-width:500px){main{padding:9px}.choice-grid,.two{grid-template-columns:1fr}.inline{grid-template-columns:1fr}.inline .btn{width:100%}.date-selects{grid-template-columns:1fr}.actions{display:grid;grid-template-columns:1fr 1fr}.actions .btn:last-child:nth-child(odd){grid-column:1/-1}}
</style></head><body><div class="app"><header class="top"><div class="row between"><div class="brand"><div class="logo">F</div><div>FamilyPilot<div class="tiny">Модуль 3 · обязательства</div></div></div><button id="finish" class="btn ghost small">Завершить</button></div></header><main>
<section class="hero"><div class="eyebrow">Внутренний тест Founder</div><h1>Календарь будущих платежей</h1><p>Правило обязательства создаёт отдельные платежи. Каждый платёж можно оплатить или перенести, не меняя всю цепочку.</p></section>
<section id="form" class="card stack"><div id="editBanner" class="edit hidden"><div class="row between"><strong>Редактирование правила</strong><button id="cancelEdit" class="btn ghost small">Отмена</button></div></div><div><h2 id="formTitle">Новое обязательство</h2><div class="tiny">Сохранение правила не создаёт расход. Расход появится после действия «Оплачено».</div></div>
<div id="kindGrid" class="choice-grid"><button class="choice active" data-kind="recurring">Повторяющееся<small>Каждые N дней, недель, месяцев или лет.</small></button><button class="choice" data-kind="one">Разовое<small>Один платёж на конкретную дату.</small></button></div>
<label class="field"><span>Что нужно оплатить</span><input id="title" maxlength="80" placeholder="Например, предоплата за газ"></label>
<div class="field"><span>Категория</span><div class="inline"><select id="category"></select><button id="newCatBtn" class="btn secondary">＋ Новая</button></div><div id="catPanel" class="inline-panel stack hidden"><label class="field">Новая категория<input id="newCat" maxlength="50"></label><div class="row wrap"><button id="saveCat" class="btn primary">Создать и выбрать</button><button id="cancelCat" class="btn ghost">Отмена</button></div></div></div>
<div class="two"><label class="field"><span>Ожидаемая сумма</span><input id="amount" type="number" min="0.01" max="999999.99" 