}.choice-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}.choice{border:1px solid var(--line);background:#fff;border-radius:14px;padding:12px;text-align:left;font-weight:820}.choice small{display:block;color:var(--muted);font-weight:600;margin-top:4px}.choice.active{background:var(--brand);border-color:var(--brand);color:#fff}.choice.active small{color:#d8efeb}.two{display:grid;grid-template-columns:1fr 1fr;gap:10px}.inline{display:grid;grid-template-columns:minmax(0,1fr) auto;gap:8px;align-items:end}.inline-panel{border:1px dashed #9fc7c1;background:#f5fbfa;border-radius:14px;padding:12px}.date-btn{width:100%;min-height:48px;border:1px solid var(--line);border-radius:13px;background:#fff;color:var(--ink);padding:12px;text-align:left;font-weight:700}.month-nav{display:grid;grid-template-columns:44px 1fr 44px;align-items:center;gap:8px}.month-title{text-align:center;font-size:19px;font-weight:850}.day-group{border:1px solid var(--line);border-radius:16px;overflow:hidden;background:#fff;margin-top:10px}.day-head{padding:11px 12px;background:#edf5f3;display:flex;align-items:center;justify-content:space-between;gap:8px;font-size:13px;font-weight:800}.payment{padding:12px;border-top:1px solid var(--line);display:grid;gap:9px}.payment:first-child{border-top:0}.payment-title{font-weight:830}.meta{font-size:12px;color:var(--muted);line-height:1.45}.amt{font-weight:850;white-space:nowrap}.actions{display:flex;gap:7px;flex-wrap:wrap}.actions .btn{min-height:38px;padding:7px 10px;font-size:12px}.pill{display:inline-flex;font-size:11px;border-radius:999px;padding:5px 8px;background:var(--soft);color:#0b5f59;font-weight:760}.pill.overdue{background:var(--badbg);color:var(--bad)}.pill.today{background:var(--warnbg);color:var(--warn)}.pill.paid{background:var(--okbg);color:var(--ok)}.overdue-box{border:1px solid #f1c8c2;background:#fff8f7;border-radius:17px;padding:12px;margin-bottom:12px}.empty{padding:18px;text-align:center;color:var(--muted)}.task{display:flex;align-items:flex-start;gap:9px;font-size:13px}.check{width:22px;height:22px;border-radius:50%;display:grid;place-items:center;border:1px solid var(--line);font-size:12px;flex:0 0 22px}.check.done{background:var(--brand);color:#fff}.modal{display:none;position:fixed;inset:0;z-index:50;background:rgba(6,28,23,.5);align-items:flex-end;justify-content:center}.modal.open{display:flex}.sheet{width:100%;max-width:680px;max-height:92dvh;overflow-y:auto;-webkit-overflow-scrolling:touch;background:var(--bg);border-radius:24px 24px 0 0;padding:18px 16px calc(28px + env(safe-area-inset-bottom))}.grab{width:44px;height:5px;border-radius:9px;background:#cedbd8;margin:0 auto 14px}.date-selects{display:grid;grid-template-columns:1fr 1.5fr 1.2fr;gap:8px}.date-selects select{width:100%;border:1px solid var(--line);border-radius:13px;padding:12px;background:#fff}.toast{position:fixed;left:50%;transform:translateX(-50%);bottom:18px;background:#102d27;color:#fff;border-radius:999px;padding:10px 14px;opacity:0;point