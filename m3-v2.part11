'NOT COMPLETED'}\nFinancial amounts included: NO\nResult: ${all?'FOUNDER TASKS COMPLETE':'INCOMPLETE'}`;$('finishStatus').innerHTML=all?'<strong>Все задачи выполнены.</strong>':`Выполнено задач: <strong>${done} из 4</strong>`;$('evidence').textContent=text;openM('finishModal')}
function init(){renderCats();reset();render();$('kindGrid').onclick=e=>{let b=e.target.closest('[data-kind]');if(b)setKind(b.dataset.kind)};$('endMode').onchange=toggleEnd;$('saveRule').onclick=saveRule;$('cancelEdit').onclick=reset;$('newCatBtn').onclick=()=>$('catPanel').classList.remove('hidden');$('cancelCat').onclick=()=>$('catPanel').classList.add('hidden');$('saveCat').onclick=()=>{let v=$('newCat').value.trim();if(!v)return toast('Введите название');let old=S.cats.find(x=>x.toLowerCase()===v.toLowerCase());if(!old)S.cats.push(v);renderCats();$('category').value=old||v;$('newCat').value='';$('catPanel').classList.add('hidden');save();toast('Категория создана')};$('startBtn').onclick=()=>prepDate('startDate');$('endBtn').onclick=()=>prepDate('endDate');$('moveDateBtn').onclick=()=>prepDate('moveDate');$('actualDateBtn').onclick=()=>prepDate('actualDate');$('applyDate').onclick=applyDate;$('dm').onchange=()=>days();$('dy').onchange=()=>days();$('list').onclick=action;$('overdue').onclick=action;$('tomorrow').onclick=()=>setDate('moveDate',addDays(today(),1));$('saveMove').onclick=saveMove;$('saveAmount').onclick=saveAmount;$('saveActual').onclick=saveActual;$('undoActual').onclick=undo;$('prev').onclick=()=>changeMonth(-1);$('next').onclick=()=>changeMonth(1);$('calendar').addEventListener('touchstart',e=>touchX=e.changedTouches[0].clientX,{passive:true});$('calendar').addEventListener('touchend',e=>{let dx=e.changedTouches[0].clientX-touchX;if(Math.abs(dx)>65)changeMonth(dx>0?-1:1)},{passive:true});document.querySelectorAll('[data-close]').forEach(b=>b.onclick=()=>closeM(b.closest('.modal')));document.querySelectorAll('.modal').forEach(m=>m.onclick=e=>{if(e.target===m)closeM(m)});$('clear').onclick=()=>{if(confirm('Удалить тестовые данные M3?')){localStorage.removeItem(K);S=load();month=monthStart(today());reset();render();toast('Данные удалены')}};$('finish').onclick=finish;$('copy').onclick=async()=>{try{await navigator.clipboard.writeText($('evidence').textContent);toast('Результат скопирован')}catch(e){toast('Не удалось скопировать')}}}document.readyState==='loading'?document.addEventListener('DOMContentLoaded',init,{once:true}):init()})();
</script></body></html>
